---
import type { ItemsTabsMeta } from "../lib/site-types";

interface Props {
  itemsTabs: ItemsTabsMeta;
  nodeId: string;
  activeTabId: string;
  pagePath: (id: string) => string;
  tabPath: (id: string, tabId: string) => string;
}

const { itemsTabs, nodeId, activeTabId, pagePath, tabPath } = Astro.props;
---

<nav class="tome-database-view-tabs" aria-label="Table tabs">
  {
    itemsTabs.items.map((tab) => {
      const isActive = tab.id === activeTabId;
      const href =
        tab.id === itemsTabs.defaultTabId
          ? pagePath(nodeId)
          : tabPath(nodeId, tab.id);
      return (
        <a
          href={href}
          class={`tome-database-view-tab${isActive ? " is-active" : ""}`}
          aria-current={isActive ? "page" : undefined}
        >
          {tab.label}
        </a>
      );
    })
  }
</nav>

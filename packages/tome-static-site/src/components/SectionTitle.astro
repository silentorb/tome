---
interface Props {
  title: string;
  typeNodeId?: string | null;
  pagePath: (id: string) => string;
}

const { title, typeNodeId, pagePath } = Astro.props;
---

<h2 class="tome-record-section-title">
  {
    typeNodeId ? (
      <a class="tome-record-section-title-link" href={pagePath(typeNodeId)}>
        {title}
      </a>
    ) : (
      title
    )
  }
</h2>

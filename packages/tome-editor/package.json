{
  "name": "tome-editor",
  "description": "Browser markdown editor for design nodes in the Tome content graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:api & bun run dev:webview",
    "dev:api": "bun --watch src/api/server.ts",
    "dev:webview": "vite",
    "build": "bun run build:webview",
    "build:webview": "vite build",
    "test": "bun run typecheck && bun test --preload ./tests/test-setup.ts tests",
    "typecheck": "tsc -p tsconfig.check.json --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@milkdown/crepe": "7.20.0",
    "tome-db": "workspace:*",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.23",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.8.2",
    "vite": "6.2.2",
    "@happy-dom/global-registrator": "17.4.4",
    "@testing-library/react": "16.2.0",
    "happy-dom": "17.4.4"
  }
}
